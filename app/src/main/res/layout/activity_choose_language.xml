<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="views.ChooseLanguageActivity"
    android:orientation="vertical">



    <RelativeLayout
        android:id="@+id/choose_lang_main_rel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/choose_lang_ok_btn"
        android:gravity="center">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/choose_language_english_btn"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_width_min"
            android:text="english" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/choose_language_persian_btn"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/button_width_min"
            android:layout_marginEnd="@dimen/high_margin"
            android:layout_toStartOf="@+id/choose_language_english_btn"
            android:text="فارسی" />

    </RelativeLayout>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/choose_lang_ok_btn"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/button_width_min"
        android:layout_alignParentStart="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="@dimen/low_margin"
        android:text="@string/accept" />



</RelativeLayout>